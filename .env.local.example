# Copy this file to .env.local and fill in your Supabase project values.
# Never commit .env.local — it is listed in .gitignore.

# ── Public (safe to expose in browser bundle) ─────────────────────────────────
# Required at runtime for the frontend Supabase client.
# Must also be set in Vercel → Project Settings → Environment Variables → Production.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Server-only (NEVER expose to browser or commit to Git) ────────────────────
# Used only by local setup/migration scripts (scripts/*.ts).
# Do NOT add these to Vercel for a purely static/client-side frontend.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Direct Postgres connection — used by migration scripts only.
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Facturatie portal integration (server-only) ───────────────────────────────
# Used ONLY by the Next.js API route /api/facturatie/revenue — never browser code.
# Add these to Vercel → Project Settings → Environment Variables → Production.
# Do NOT prefix with NEXT_PUBLIC_.
FACTURATIE_API_URL=https://facturatie.bitebrands.nl
FACTURATIE_CRM_API_TOKEN=<crm-api-token-from-facturatie-portal>
